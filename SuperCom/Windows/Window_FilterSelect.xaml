<super:BaseWindow
    x:Class="SuperCom.Windows.Window_FilterSelect"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SuperCom.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:super="https://github.com/SuperStudio/SuperControls"
    Name="filterSelectWindow"
    Title="{DynamicResource SelectFilterRule}"
    Width="400"
    Height="300"
    Background="{DynamicResource Window.Background}"
    Foreground="{DynamicResource Window.Foreground}"
    Icon="pack://application:,,,/Resources/Ico/ICON.ico"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Border
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="5">
            <ListBox
                Name="listBox"
                DisplayMemberPath="RuleName"
                ItemsSource="{Binding FilterRules}"
                SelectedItem="{Binding SelectedRule}"
                Style="{StaticResource NormalListBox}"
                ItemContainerStyle="{StaticResource NormalListBoxItem}" />
        </Border>

        <StackPanel
            Grid.Row="1"
            Margin="0,10,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="5"
                Click="Confirm"
                Content="{DynamicResource Confirm}"
                IsDefault="True"
                Style="{StaticResource ButtonPrimary}" />
            <Button
                Margin="5"
                Click="Cancel"
                Content="{DynamicResource Cancel}"
                IsCancel="True"
                Style="{StaticResource FlatButton}" />
        </StackPanel>
    </Grid>
</super:BaseWindow>