<super:BaseWindow
    x:Class="SuperCom.Windows.Window_FilterTest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SuperCom.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:super="https://github.com/SuperStudio/SuperControls"
    Name="filterTestWindow"
    Title="{DynamicResource FilterTestTitle}"
    Width="600"
    Height="450"
    Background="{DynamicResource Window.Background}"
    Foreground="{DynamicResource Window.Foreground}"
    Icon="pack://application:,,,/Resources/Ico/ICON.ico"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!-- 输入区域 -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,5"
            FontWeight="Bold"
            Text="{DynamicResource InputData}" />

        <Border
            Grid.Row="1"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="5">
            <TextBox
                Name="txtInput"
                Margin="5"
                AcceptsReturn="True"
                Background="Transparent"
                Style="{StaticResource MultiLineTextBox}"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto" />
        </Border>

        <!-- 规则选择 -->
        <StackPanel
            Grid.Row="2"
            Margin="0,10"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                Text="{DynamicResource SelectRule}" />
            <ComboBox
                Name="cmbRules"
                Margin="10,0"
                DisplayMemberPath="RuleName"
                Style="{StaticResource BorderComboBox}" />
            <Button
                Margin="10,0,0,0"
                Click="RunTest"
                Content="{DynamicResource RunTest}"
                Style="{StaticResource ButtonPrimary}" />
        </StackPanel>

        <!-- 输出区域 -->
        <TextBlock
            Grid.Row="3"
            Margin="0,0,0,5"
            FontWeight="Bold"
            Text="{DynamicResource FilterResult}" />

        <Border
            Grid.Row="4"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="5">
            <TextBox
                Name="txtOutput"
                Margin="5"
                AcceptsReturn="True"
                Background="Transparent"
                IsReadOnly="True"
                Style="{StaticResource ReadOnlyTextBox}"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto" />
        </Border>
    </Grid>
</super:BaseWindow>