<super:BaseWindow
    x:Class="SuperCom.Windows.Window_FilterTest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SuperCom.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:super="https://github.com/SuperStudio/SuperControls"
    Name="filterTestWindow"
    Title="{DynamicResource FilterTestTitle}"
    Width="650"
    Height="500"
    Background="{DynamicResource Window.Background}"
    Foreground="{DynamicResource Window.Foreground}"
    Icon="pack://application:,,,/Resources/Ico/ICON.ico"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 输入区域标题 -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,8"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="5"
            Padding="10,5">
            <TextBlock
                FontWeight="Bold"
                Foreground="{DynamicResource Window.Foreground}"
                Text="{DynamicResource InputData}" />
        </Border>

        <!-- 输入区域 -->
        <Border
            Grid.Row="1"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="8"
            Padding="8">
            <Border
                Background="{DynamicResource Window.Title.Background}"
                CornerRadius="5">
                <TextBox
                    Name="txtInput"
                    Margin="8"
                    AcceptsReturn="True"
                    Background="Transparent"
                    BorderThickness="0"
                    CaretBrush="{DynamicResource Window.Foreground}"
                    FontFamily="Consolas"
                    FontSize="13"
                    Foreground="{DynamicResource Window.Foreground}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </Border>
        </Border>

        <!-- 规则选择 -->
        <Border
            Grid.Row="2"
            Margin="0,10"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="5"
            Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource Window.Foreground}"
                    Opacity="0.7"
                    Text="{DynamicResource SelectRule}" />
                <ComboBox
                    Name="cmbRules"
                    Width="200"
                    Margin="15,0"
                    DisplayMemberPath="RuleName"
                    Style="{StaticResource BorderComboBox}" />
                <Button
                    MinWidth="80"
                    Click="RunTest"
                    Content="{DynamicResource RunTest}"
                    Style="{StaticResource ButtonPrimary}" />
            </StackPanel>
        </Border>

        <!-- 输出区域标题 -->
        <Border
            Grid.Row="3"
            Margin="0,0,0,8"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="5"
            Padding="10,5">
            <TextBlock
                FontWeight="Bold"
                Foreground="{DynamicResource Window.Foreground}"
                Text="{DynamicResource FilterResult}" />
        </Border>

        <!-- 输出区域 -->
        <Border
            Grid.Row="4"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="8"
            Padding="8">
            <Border
                Background="{DynamicResource Window.Title.Background}"
                CornerRadius="5">
                <TextBox
                    Name="txtOutput"
                    Margin="8"
                    AcceptsReturn="True"
                    Background="Transparent"
                    BorderThickness="0"
                    CaretBrush="{DynamicResource Window.Foreground}"
                    FontFamily="Consolas"
                    FontSize="13"
                    Foreground="{DynamicResource Window.Foreground}"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </Border>
        </Border>
    </Grid>
</super:BaseWindow>