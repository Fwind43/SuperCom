<super:BaseWindow
    x:Class="SuperCom.Windows.Window_SinglePort"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:config="clr-namespace:SuperCom.Config"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SuperCom.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:super="https://github.com/SuperStudio/SuperControls"
    Name="singlePortWindow"
    Title="{Binding PortName}"
    Width="900"
    Height="600"
    Background="{DynamicResource Window.Background}"
    Closing="BaseWindow_Closing"
    Foreground="{DynamicResource Window.Foreground}"
    Icon="pack://application:,,,/Resources/Ico/ICON.ico"
    Loaded="BaseWindow_Loaded"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部状态栏 -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,8"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="8"
            Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Margin="0,0,20,0"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource Window.Foreground}"
                        Opacity="0.7"
                        Text="{DynamicResource Port}" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Window.Foreground}"
                        Text="{Binding PortName}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Margin="0,0,20,0"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource Window.Foreground}"
                        Opacity="0.7"
                        Text="{DynamicResource Status}" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontWeight="Bold"
                        Text="{Binding StatusText}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Margin="0,0,20,0"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="#4CAF50"
                        FontWeight="Medium"
                        Text="RX:" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource Window.Foreground}"
                        Text="{Binding RX, StringFormat={}{0:N0}}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="3"
                    Margin="0,0,20,0"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="#2196F3"
                        FontWeight="Medium"
                        Text="TX:" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource Window.Foreground}"
                        Text="{Binding TX, StringFormat={}{0:N0}}" />
                </StackPanel>

                <Button
                    Grid.Column="5"
                    MinWidth="80"
                    Click="ToggleConnect"
                    Content="{Binding ConnectButtonText}"
                    Style="{StaticResource ButtonPrimary}" />
            </Grid>
        </Border>

        <!-- 接收区域 -->
        <Border
            Grid.Row="1"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="8"
            Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 工具栏 -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    Background="{DynamicResource Window.Title.Background}"
                    CornerRadius="5"
                    Padding="8,5">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Padding="12,4"
                            Click="ClearData"
                            Content="{DynamicResource Clear}"
                            Style="{StaticResource FlatButton}" />
                        <Separator
                            Width="1"
                            Margin="0,0,8,0"
                            Background="{DynamicResource Window.Foreground}"
                            Opacity="0.2" />
                        <CheckBox
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource ShowHex}"
                            Foreground="{DynamicResource Window.Foreground}"
                            IsChecked="{Binding RecvShowHex}"
                            Style="{StaticResource NormalCheckBox}" />
                        <CheckBox
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource ShowTimeStamp}"
                            Foreground="{DynamicResource Window.Foreground}"
                            IsChecked="{Binding AddTimeStamp}"
                            Style="{StaticResource NormalCheckBox}" />
                        <Separator
                            Width="1"
                            Margin="0,0,8,0"
                            Background="{DynamicResource Window.Foreground}"
                            Opacity="0.2" />
                        <Button
                            Padding="12,4"
                            Click="ExportData"
                            Content="{DynamicResource Export}"
                            Style="{StaticResource FlatButton}" />
                    </StackPanel>
                </Border>

                <!-- 文本编辑器 -->
                <Border
                    Grid.Row="1"
                    Background="{DynamicResource Window.Title.Background}"
                    CornerRadius="5">
                    <avalonedit:TextEditor
                        Name="textEditor"
                        Margin="5"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="13"
                        Foreground="{DynamicResource Window.Foreground}"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        ShowLineNumbers="True"
                        VerticalScrollBarVisibility="Auto"
                        WordWrap="True" />
                </Border>
            </Grid>
        </Border>

        <!-- 发送区域 -->
        <Border
            Grid.Row="2"
            Margin="0,8,0,0"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="8"
            Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 发送选项 -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    Background="{DynamicResource Window.Title.Background}"
                    CornerRadius="5"
                    Padding="8,5">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox
                            Margin="0,0,15,0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource SendHex}"
                            Foreground="{DynamicResource Window.Foreground}"
                            IsChecked="{Binding SendHex}"
                            Style="{StaticResource NormalCheckBox}" />
                        <CheckBox
                            Margin="0,0,15,0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource AddNewLine}"
                            Foreground="{DynamicResource Window.Foreground}"
                            IsChecked="{Binding AddNewLineWhenWrite}"
                            Style="{StaticResource NormalCheckBox}" />

                        <!-- 进制转换下拉框 -->
                        <Separator
                            Width="1"
                            Margin="0,0,15,0"
                            Background="{DynamicResource Window.Foreground}"
                            Opacity="0.2" />
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource Window.Foreground}"
                            Opacity="0.7"
                            Text="{DynamicResource ConvertFormat}" />
                        <ComboBox
                            Width="160"
                            DisplayMemberPath="Value"
                            ItemsSource="{Binding DataConvertTypes}"
                            SelectedIndex="{Binding DataConvertIndex}"
                            SelectedValuePath="Key"
                            Style="{StaticResource BorderComboBox}" />
                    </StackPanel>
                </Border>

                <!-- 发送输入框 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Margin="0,0,8,0"
                        Background="{DynamicResource Window.Title.Background}"
                        CornerRadius="5">
                        <TextBox
                            Name="sendTextBox"
                            Margin="8"
                            AcceptsReturn="True"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{DynamicResource Window.Foreground}"
                            Foreground="{DynamicResource Window.Foreground}"
                            Text="{Binding WriteData, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto" />
                    </Border>

                    <Button
                        Grid.Column="1"
                        Width="80"
                        Click="SendData"
                        Content="{DynamicResource Send}"
                        Style="{StaticResource ButtonPrimary}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</super:BaseWindow>