<super:BaseWindow
    x:Class="SuperCom.Windows.Window_DataFilter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:config="clr-namespace:SuperCom.Config"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SuperCom.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:super="https://github.com/SuperStudio/SuperControls"
    Name="dataFilterWindow"
    Title="{DynamicResource DataFilterTitle}"
    Width="750"
    Height="520"
    Background="{DynamicResource Window.Background}"
    Closing="BaseWindow_Closing"
    Foreground="{DynamicResource Window.Foreground}"
    Icon="pack://application:,,,/Resources/Ico/ICON.ico"
    Loaded="BaseWindow_Loaded"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="8"
            Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Window.Foreground}"
                    Text="{DynamicResource DataFilterTitle}" />
                <TextBlock
                    Margin="15,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource Window.Foreground}"
                    Opacity="0.6"
                    Text="{DynamicResource DataFilterDesc}" />
            </StackPanel>
        </Border>

        <!-- 规则列表 -->
        <Border
            Grid.Row="1"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="8"
            Padding="10">
            <DataGrid
                Name="dataGrid"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="{DynamicResource DataGrid.HorizontalGridLinesBrush}"
                IsReadOnly="True"
                ItemsSource="{Binding FilterRules}"
                RowBackground="Transparent"
                SelectedItem="{Binding SelectedRule}"
                SelectionMode="Single">
                <DataGrid.Resources>
                    <Style BasedOn="{StaticResource {x:Type DataGridColumnHeader}}" TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{DynamicResource Window.Foreground}" />
                        <Setter Property="Padding" Value="10,8" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="BorderBrush" Value="{DynamicResource DataGrid.HorizontalGridLinesBrush}" />
                    </Style>
                    <Style BasedOn="{StaticResource {x:Type DataGridRow}}" TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource Window.Foreground}" />
                        <Setter Property="Height" Value="36" />
                    </Style>
                    <Style BasedOn="{StaticResource {x:Type DataGridCell}}" TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="Padding" Value="5,0" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding RuleName}"
                        Header="{DynamicResource RuleName}" />
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding MatchType}"
                        Header="{DynamicResource MatchType}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding MatchPattern}"
                        Header="{DynamicResource MatchPattern}" />
                    <DataGridCheckBoxColumn
                        Width="70"
                        Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                        Header="{DynamicResource Enabled}">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="Foreground" Value="{DynamicResource Window.Foreground}" />
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>
                    <DataGridTemplateColumn Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    Padding="12,4"
                                    Click="EditRule"
                                    Content="{DynamicResource Edit}"
                                    Style="{StaticResource FlatButton}"
                                    Tag="{Binding RuleID}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 底部按钮 -->
        <Border
            Grid.Row="2"
            Margin="0,10,0,0"
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="8"
            Padding="10">
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    MinWidth="80"
                    Click="AddRule"
                    Content="{DynamicResource Add}"
                    Style="{StaticResource ButtonPrimary}" />
                <Button
                    MinWidth="80"
                    Margin="10,0,0,0"
                    Click="DeleteRule"
                    Content="{DynamicResource Delete}"
                    Style="{StaticResource ButtonDanger}" />
                <Button
                    MinWidth="80"
                    Margin="10,0,0,0"
                    Click="TestFilter"
                    Content="{DynamicResource TestFilter}"
                    Style="{StaticResource FlatButton}" />
                <Button
                    MinWidth="80"
                    Margin="10,0,0,0"
                    Click="Close"
                    Content="{DynamicResource Close}"
                    Style="{StaticResource FlatButton}" />
            </StackPanel>
        </Border>

        <!-- 编辑弹窗 -->
        <Popup
            x:Name="editPopup"
            Width="450"
            Height="auto"
            AllowsTransparency="True"
            Placement="Center"
            PopupAnimation="Fade"
            StaysOpen="True">
            <Grid Margin="5">
                <Border
                    Margin="5"
                    Background="{DynamicResource Window.Background}"
                    CornerRadius="10"
                    Effect="{StaticResource PopupDropShadowEffect}" />
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 弹窗标题 -->
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,15"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Window.Foreground}"
                        Text="{DynamicResource EditFilterRule}" />

                    <!-- 规则名称 -->
                    <Border
                        Grid.Row="1"
                        Margin="0,0,0,10"
                        Background="{DynamicResource Window.Side.Background}"
                        CornerRadius="5"
                        Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource Window.Foreground}"
                                Opacity="0.7"
                                Text="{DynamicResource RuleName}" />
                            <super:SearchBox
                                Grid.Column="1"
                                Name="txtRuleName"
                                PlaceHolder="{DynamicResource RuleNamePlaceholder}" />
                        </Grid>
                    </Border>

                    <!-- 匹配类型 -->
                    <Border
                        Grid.Row="2"
                        Margin="0,0,0,10"
                        Background="{DynamicResource Window.Side.Background}"
                        CornerRadius="5"
                        Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource Window.Foreground}"
                                Opacity="0.7"
                                Text="{DynamicResource MatchType}" />
                            <ComboBox
                                Grid.Column="1"
                                Name="cmbMatchType"
                                DisplayMemberPath="Value"
                                SelectedValuePath="Key"
                                Style="{StaticResource BorderComboBox}" />
                        </Grid>
                    </Border>

                    <!-- 匹配模式 -->
                    <Border
                        Grid.Row="3"
                        Margin="0,0,0,10"
                        Background="{DynamicResource Window.Side.Background}"
                        CornerRadius="5"
                        Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource Window.Foreground}"
                                Opacity="0.7"
                                Text="{DynamicResource MatchPattern}" />
                            <super:SearchBox
                                Grid.Column="1"
                                Name="txtMatchPattern"
                                PlaceHolder="{DynamicResource MatchPatternPlaceholder}" />
                        </Grid>
                    </Border>

                    <!-- 描述 -->
                    <Border
                        Grid.Row="4"
                        Margin="0,0,0,10"
                        Background="{DynamicResource Window.Side.Background}"
                        CornerRadius="5"
                        Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Top"
                                Margin="0,8,0,0"
                                Foreground="{DynamicResource Window.Foreground}"
                                Opacity="0.7"
                                Text="{DynamicResource Description}" />
                            <TextBox
                                Grid.Column="1"
                                Name="txtDescription"
                                Height="70"
                                AcceptsReturn="True"
                                Background="Transparent"
                                BorderThickness="0"
                                CaretBrush="{DynamicResource Window.Foreground}"
                                Foreground="{DynamicResource Window.Foreground}"
                                Style="{StaticResource MultiLineTextBox}"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>

                    <!-- 按钮区域 -->
                    <StackPanel
                        Grid.Row="5"
                        Margin="0,5,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            MinWidth="80"
                            Click="SaveRule"
                            Content="{DynamicResource Save}"
                            Style="{StaticResource ButtonPrimary}" />
                        <Button
                            MinWidth="80"
                            Margin="10,0,0,0"
                            Click="CancelEdit"
                            Content="{DynamicResource Cancel}"
                            Style="{StaticResource FlatButton}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Popup>
    </Grid>
</super:BaseWindow>