<super:BaseWindow
    x:Class="SuperCom.Windows.Window_DataFilter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:config="clr-namespace:SuperCom.Config"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SuperCom.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:super="https://github.com/SuperStudio/SuperControls"
    Name="dataFilterWindow"
    Title="{DynamicResource DataFilterTitle}"
    Width="700"
    Height="500"
    Background="{DynamicResource Window.Background}"
    Closing="BaseWindow_Closing"
    Foreground="{DynamicResource Window.Foreground}"
    Icon="pack://application:,,,/Resources/Ico/ICON.ico"
    Loaded="BaseWindow_Loaded"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!-- 规则列表 -->
        <Border
            Background="{DynamicResource Window.Side.Background}"
            CornerRadius="5">
            <DataGrid
                Name="dataGrid"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="{DynamicResource DataGrid.HorizontalGridLinesBrush}"
                IsReadOnly="True"
                ItemsSource="{Binding FilterRules}"
                RowBackground="Transparent"
                SelectedItem="{Binding SelectedRule}"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding RuleName}"
                        Header="{DynamicResource RuleName}" />
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding MatchType}"
                        Header="{DynamicResource MatchType}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding MatchPattern}"
                        Header="{DynamicResource MatchPattern}" />
                    <DataGridCheckBoxColumn
                        Width="60"
                        Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                        Header="{DynamicResource Enabled}" />
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Margin="2"
                                        Click="EditRule"
                                        Content="{DynamicResource Edit}"
                                        Style="{StaticResource ButtonPrimary}"
                                        Tag="{Binding RuleID}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel
            Grid.Row="1"
            Margin="0,10,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="5"
                Click="AddRule"
                Content="{DynamicResource Add}"
                Style="{StaticResource ButtonPrimary}" />
            <Button
                Margin="5"
                Click="DeleteRule"
                Content="{DynamicResource Delete}"
                Style="{StaticResource ButtonDanger}" />
            <Button
                Margin="5"
                Click="TestFilter"
                Content="{DynamicResource TestFilter}"
                Style="{StaticResource FlatButton}" />
            <Button
                Margin="5"
                Click="Close"
                Content="{DynamicResource Close}"
                Style="{StaticResource FlatButton}" />
        </StackPanel>

        <!-- 编辑弹窗 -->
        <Popup
            x:Name="editPopup"
            Width="400"
            Height="auto"
            AllowsTransparency="True"
            Placement="Center"
            PopupAnimation="Fade"
            StaysOpen="True">
            <Grid Margin="5">
                <Border
                    Margin="5"
                    Background="{DynamicResource Menu.Background}"
                    CornerRadius="5"
                    Effect="{StaticResource PopupDropShadowEffect}" />
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        FontWeight="Bold"
                        Text="{DynamicResource EditFilterRule}" />

                    <DockPanel Grid.Row="1" Margin="0,5">
                        <TextBlock
                            Width="80"
                            VerticalAlignment="Center"
                            Text="{DynamicResource RuleName}" />
                        <super:SearchBox Name="txtRuleName" />
                    </DockPanel>

                    <DockPanel Grid.Row="2" Margin="0,5">
                        <TextBlock
                            Width="80"
                            VerticalAlignment="Center"
                            Text="{DynamicResource MatchType}" />
                        <ComboBox
                            Name="cmbMatchType"
                            DisplayMemberPath="Value"
                            SelectedValuePath="Key"
                            Style="{StaticResource BorderComboBox}" />
                    </DockPanel>

                    <DockPanel Grid.Row="3" Margin="0,5">
                        <TextBlock
                            Width="80"
                            VerticalAlignment="Center"
                            Text="{DynamicResource MatchPattern}" />
                        <super:SearchBox Name="txtMatchPattern" />
                    </DockPanel>

                    <DockPanel Grid.Row="4" Margin="0,5">
                        <TextBlock
                            Width="80"
                            VerticalAlignment="Center"
                            Text="{DynamicResource Description}" />
                        <TextBox
                            Name="txtDescription"
                            AcceptsReturn="True"
                            Height="60"
                            Style="{StaticResource SearchTextBoxStyle}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto" />
                    </DockPanel>

                    <StackPanel
                        Grid.Row="5"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Margin="5"
                            Click="SaveRule"
                            Content="{DynamicResource Save}"
                            Style="{StaticResource ButtonPrimary}" />
                        <Button
                            Margin="5"
                            Click="CancelEdit"
                            Content="{DynamicResource Cancel}"
                            Style="{StaticResource FlatButton}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Popup>
    </Grid>
</super:BaseWindow>